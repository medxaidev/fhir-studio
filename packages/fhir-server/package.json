{
  "name": "fhir-server",
  "version": "0.3.0",
  "description": "FHIR R4 REST API Server",
  "homepage": "https://github.com/nicefhir/fhir-studio",
  "license": "MIT",
  "author": "Fangjun <fangjun20208@gmail.com>",
  "keywords": [
    "typescript",
    "FHIR",
    "server"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/nicefhir/fhir-studio.git",
    "directory": "packages/fhir-server"
  },
  "sideEffects": false,
  "type": "module",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.mjs"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && tsc && node ./scripts/esbuild.mjs",
    "dev": "tsx watch ./scripts/dev.ts",
    "start": "tsx ./scripts/dev.ts",
    "start:prod": "tsx ./scripts/dev.ts --config fhir.config.railway.json",
    "test": "vitest"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "fastify": "5.7.4",
    "fhir-engine": "^0.6.0",
    "jose": "^6.1.3",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "esbuild": "^0.24.2",
    "typescript": "^5.7.3"
  }
}
